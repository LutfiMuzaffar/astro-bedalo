---
// Material Symbols Outlined wrapper. Mirrors the inline `<span>` markup
// used throughout the source pages and centralizes the FILL/wght variations.
interface Props {
  name: string;
  filled?: boolean;
  weight?: 100 | 200 | 300 | 400 | 500 | 600 | 700;
  class?: string;
  size?: number;
  style?: string;
}

const { name, filled = false, weight = 400, class: className = '', size, style: styleProp } = Astro.props;

const fontVariation = `'FILL' ${filled ? 1 : 0}, 'wght' ${weight}, 'GRAD' 0, 'opsz' 24`;
const styleParts = [`font-variation-settings: ${fontVariation}`];
if (size) styleParts.push(`font-size: ${size}px`);
if (styleProp) styleParts.push(styleProp);
const style = styleParts.join('; ');
---
<span class={`material-symbols-outlined ${className}`.trim()} style={style}>{name}</span>
