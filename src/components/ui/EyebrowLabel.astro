---
import Icon from '@components/ui/Icon.astro';

interface Props {
  text: string;
  icon?: string;
  tone?: 'primary-fixed' | 'tertiary-fixed' | 'surface-container';
  class?: string;
}

const { text, icon, tone = 'primary-fixed', class: className = '' } = Astro.props;

const toneClass = {
  'primary-fixed': 'bg-primary-fixed text-on-primary-fixed-variant',
  'tertiary-fixed': 'bg-tertiary-fixed text-on-tertiary-fixed-variant',
  'surface-container': 'bg-surface-container text-on-surface-variant',
}[tone];
---
<div
  class={`inline-flex items-center gap-2 px-4 py-1 rounded-full text-label-caps font-label-caps ${toneClass} ${className}`.trim()}
>
  {icon && <Icon name={icon} size={16} />}
  {text}
</div>
