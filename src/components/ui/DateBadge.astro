---
import { formatDay, formatMonthShort } from '@lib/date';

interface Props {
  date: Date;
  variant?: 'primary' | 'tertiary';
  class?: string;
}

const { date, variant = 'primary', class: className = '' } = Astro.props;

const variantClass = {
  primary: 'bg-primary text-on-primary',
  tertiary: 'bg-tertiary-fixed text-on-tertiary-fixed-variant',
}[variant];
---
<div class={`flex flex-col items-center justify-center w-16 h-16 rounded-2xl ${variantClass} ${className}`.trim()}>
  <span class="font-display-lg text-[24px] leading-none font-bold">{formatDay(date)}</span>
  <span class="font-label-caps text-label-caps mt-1">{formatMonthShort(date)}</span>
</div>
