---
import Icon from '@components/ui/Icon.astro';

interface Props {
  href: string;
  cover: string;
  coverAlt: string;
  klpBadge: string;
  universitas: string;
  semester: string;
  anggotaCount: number;
  prokerCount: number;
}

const {
  href,
  cover,
  coverAlt,
  klpBadge,
  universitas,
  semester,
  anggotaCount,
  prokerCount,
} = Astro.props;
---
<article class="bg-surface-container-lowest rounded-[24px] overflow-hidden flex flex-col group shadow-[0_8px_20px_-10px_rgba(2,62,138,0.06)] hover:shadow-[0_12px_30px_-10px_rgba(2,62,138,0.12)] transition-shadow duration-300">
  <div class="relative h-48 bg-surface-container overflow-hidden">
    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src={cover} alt={coverAlt} />
    <div class="absolute top-4 left-4 bg-tertiary-container text-on-tertiary-container font-label-caps text-label-caps px-3 py-1.5 rounded-full backdrop-blur-md">
      {klpBadge}
    </div>
  </div>
  <div class="p-6 flex flex-col flex-grow">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h3 class="font-headline-sm text-headline-sm text-on-surface mb-1">{universitas}</h3>
        <p class="text-on-surface-variant text-sm">{semester}</p>
      </div>
    </div>
    <div class="flex gap-4 mb-6 text-sm">
      <div class="flex items-center gap-1.5 text-on-surface-variant">
        <Icon name="group" size={18} />
        <span>{anggotaCount} Anggota</span>
      </div>
      <div class="flex items-center gap-1.5 text-on-surface-variant">
        <Icon name="task_alt" size={18} />
        <span>{prokerCount} Proker</span>
      </div>
    </div>
    <div class="mt-auto pt-4 border-t border-surface-variant/50">
      <a
        class="inline-flex items-center gap-2 text-primary font-medium hover:text-on-secondary-fixed-variant transition-colors group/link"
        href={href}
      >
        Lihat Detail
        <Icon name="arrow_forward" size={20} class="group-hover/link:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>
</article>
