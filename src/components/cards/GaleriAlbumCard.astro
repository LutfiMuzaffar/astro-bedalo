---
import { formatLong } from '@lib/date';

interface Props {
  href: string;
  title: string;
  subtitle?: string;
  cover: string;
  coverAlt: string;
  publishedAt: Date;
  photoCount: number;
  class?: string;
}

const { href, title, subtitle, cover, coverAlt, publishedAt, photoCount, class: className = '' } = Astro.props;
---
<a
  href={href}
  class={`group relative block aspect-[4/3] overflow-hidden rounded-[24px] shadow-md hover:shadow-xl transition-shadow ${className}`.trim()}
>
  <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
  <div class="absolute inset-0 bg-gradient-to-t from-on-secondary-container/90 via-on-secondary-container/30 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 p-6 text-white space-y-2">
    <p class="text-label-caps text-white/80">{formatLong(publishedAt)} · {photoCount} foto</p>
    <h4 class="font-headline-sm text-headline-sm">{title}</h4>
    {subtitle && <p class="text-body-md text-white/80 line-clamp-2">{subtitle}</p>}
  </div>
</a>
