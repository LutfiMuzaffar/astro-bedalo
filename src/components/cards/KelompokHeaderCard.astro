---
interface MetaItem {
  label: string;
  value: string;
}

interface Props {
  cover: string;
  coverAlt: string;
  title: string;
  subtitle?: string;
  meta: MetaItem[];
  /** Tailwind height class. */
  heroHeight?: string;
}

const {
  cover,
  coverAlt,
  title,
  subtitle,
  meta,
  heroHeight = 'h-[400px] md:h-[600px]',
} = Astro.props;
---
<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop mt-8 mb-section-gap">
  <div class={`relative w-full ${heroHeight} rounded-[24px] overflow-hidden shadow-[0_8px_30px_-4px_rgba(2,62,138,0.15)] group`}>
    <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src={cover} alt={coverAlt} />
    <div class="absolute inset-0 bg-gradient-to-t from-on-primary-fixed/80 via-on-primary-fixed/20 to-transparent flex flex-col justify-end p-8 md:p-12">
      <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-surface-bright mb-4 max-w-3xl">
        {title}
      </h1>
      {subtitle && (
        <p class="font-headline-sm text-headline-sm text-surface-container-low max-w-2xl opacity-90">
          {subtitle}
        </p>
      )}
    </div>
  </div>
  <div class="relative -mt-16 z-10 mx-4 md:mx-12 bg-surface-container-lowest rounded-[24px] shadow-[0_4px_20px_-4px_rgba(2,62,138,0.08)] p-6 md:p-8">
    <div class={`grid grid-cols-2 md:grid-cols-${meta.length} gap-6 md:gap-gutter`}>
      {meta.map((item) => (
        <div class="flex flex-col gap-1 border-l-2 border-primary-container pl-4">
          <span class="font-label-caps text-label-caps text-on-surface-variant uppercase">{item.label}</span>
          <span class="font-body-md text-body-md text-on-background">{item.value}</span>
        </div>
      ))}
    </div>
  </div>
</section>
