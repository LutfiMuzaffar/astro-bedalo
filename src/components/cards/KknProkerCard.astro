---
import Icon from '@components/ui/Icon.astro';

interface Props {
  href: string;
  title: string;
  summary: string;
  cover: string;
  coverAlt: string;
  kelompok: string;
  period: string;
  status: 'planning' | 'ongoing' | 'completed';
  class?: string;
}

const { href, title, summary, cover, coverAlt, kelompok, period, status, class: className = '' } = Astro.props;

const statusClass = {
  planning: 'bg-secondary-fixed text-on-secondary-fixed-variant',
  ongoing: 'bg-tertiary-fixed text-on-tertiary-fixed-variant',
  completed: 'bg-primary-fixed text-on-primary-fixed-variant',
}[status];

const statusLabel = {
  planning: 'Perencanaan',
  ongoing: 'Berjalan',
  completed: 'Selesai',
}[status];
---
<a
  href={href}
  class={`group block bg-surface-container-lowest rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl transition-shadow ${className}`.trim()}
>
  <div class="aspect-[16/9] overflow-hidden relative">
    <img class="w-full h-full object-cover transition-transform group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
    <div class={`absolute top-4 right-4 px-3 py-1 rounded-full text-label-caps font-label-caps ${statusClass}`}>{statusLabel}</div>
  </div>
  <div class="p-6 space-y-3">
    <div class="flex items-center gap-3 text-on-surface-variant text-label-caps">
      <span class="flex items-center gap-1"><Icon name="groups" size={16} /> Kelompok {kelompok}</span>
      <span class="flex items-center gap-1"><Icon name="calendar_today" size={16} /> {period}</span>
    </div>
    <h4 class="font-headline-sm text-headline-sm group-hover:text-primary transition-colors">{title}</h4>
    <p class="text-on-surface-variant text-body-md line-clamp-3">{summary}</p>
    <span class="text-primary font-bold inline-flex items-center gap-1 text-body-md">
      Lihat Detail <Icon name="arrow_forward" size={18} />
    </span>
  </div>
</a>
