---
import Icon from '@components/ui/Icon.astro';

interface Props {
  href: string;
  name: string;
  category: string;
  summary: string;
  cover: string;
  coverAlt: string;
  owner?: string;
  class?: string;
}

const { href, name, category, summary, cover, coverAlt, owner, class: className = '' } = Astro.props;

const categoryLabel = {
  kuliner: 'Kuliner',
  kerajinan: 'Kerajinan',
  jasa: 'Jasa',
  pertanian: 'Pertanian',
  lainnya: 'Lainnya',
}[category] ?? category;
---
<a
  href={href}
  class={`group block bg-surface-container-lowest rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl transition-shadow ${className}`.trim()}
>
  <div class="aspect-[4/3] overflow-hidden relative">
    <img class="w-full h-full object-cover transition-transform group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
    <div class="absolute top-4 left-4 bg-tertiary text-on-tertiary px-3 py-1 rounded-lg text-label-caps font-label-caps">
      {categoryLabel.toUpperCase()}
    </div>
  </div>
  <div class="p-6 space-y-3">
    <h4 class="font-headline-sm text-headline-sm group-hover:text-primary transition-colors">{name}</h4>
    {owner && (
      <p class="flex items-center gap-1 text-on-surface-variant text-label-caps">
        <Icon name="person" size={14} /> {owner}
      </p>
    )}
    <p class="text-on-surface-variant text-body-md line-clamp-3">{summary}</p>
  </div>
</a>
