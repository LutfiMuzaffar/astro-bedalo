---
import Icon from '@components/ui/Icon.astro';

type Variant = 'default' | 'feature' | 'tile';

interface Props {
  href: string;
  name: string;
  tagline: string;
  cover: string;
  coverAlt: string;
  type: string;
  facilities?: string[];
  variant?: Variant;
  class?: string;
}

const {
  href,
  name,
  tagline,
  cover,
  coverAlt,
  type,
  facilities = [],
  variant = 'default',
  class: className = '',
} = Astro.props;

const typeLabel = {
  pantai: 'Pantai',
  gua: 'Gua',
  'air-terjun': 'Air Terjun',
  bukit: 'Bukit',
  lainnya: 'Lainnya',
}[type] ?? type;
---
{variant === 'feature' && (
  <a
    href={href}
    class={`group relative overflow-hidden rounded-[24px] aspect-[16/9] shadow-md hover:-translate-y-2 transition-transform duration-500 block ${className}`.trim()}
  >
    <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-on-secondary-container/90 via-on-secondary-container/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 p-8">
      <span class="bg-secondary text-on-secondary px-3 py-1 rounded-full text-label-caps text-[10px] mb-4 inline-block">WISATA ALAM</span>
      <h3 class="text-white font-headline-md text-headline-md mb-2">{name}</h3>
      <p class="text-surface-variant/90 max-w-md">{tagline}</p>
    </div>
  </a>
)}

{variant === 'tile' && (
  <a
    href={href}
    class={`group relative overflow-hidden rounded-[24px] aspect-square shadow-md hover:-translate-y-2 transition-transform duration-500 block ${className}`.trim()}
  >
    <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-tertiary-container/90 to-transparent"></div>
    <div class="absolute bottom-0 left-0 p-6">
      <span class="bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-label-caps text-[10px] mb-4 inline-block">{typeLabel.toUpperCase()}</span>
      <h3 class="text-white font-headline-sm text-headline-sm mb-2">{name}</h3>
      <p class="text-white/80 text-body-md">{tagline}</p>
    </div>
  </a>
)}

{variant === 'default' && (
  <a
    href={href}
    class={`group block bg-surface-container-lowest rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl transition-shadow ${className}`.trim()}
  >
    <div class="aspect-[4/3] overflow-hidden relative">
      <img class="w-full h-full object-cover transition-transform group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
      <div class="absolute top-4 left-4 bg-primary text-on-primary px-3 py-1 rounded-lg text-label-caps font-label-caps">
        {typeLabel.toUpperCase()}
      </div>
    </div>
    <div class="p-6 space-y-3">
      <h4 class="font-headline-sm text-headline-sm group-hover:text-primary transition-colors">{name}</h4>
      <p class="text-on-surface-variant text-body-md line-clamp-2">{tagline}</p>
      {facilities.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {facilities.slice(0, 3).map((f) => (
            <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-[11px] bg-surface-container text-on-surface-variant">
              <Icon name="check_circle" size={12} /> {f}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
)}
