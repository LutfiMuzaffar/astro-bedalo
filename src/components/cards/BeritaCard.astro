---
import Icon from '@components/ui/Icon.astro';
import { formatLong } from '@lib/date';

type Variant = 'default' | 'featured' | 'horizontal' | 'compact';

interface Props {
  href: string;
  title: string;
  excerpt: string;
  cover: string;
  coverAlt: string;
  publishedAt: Date;
  category: string;
  variant?: Variant;
  class?: string;
}

const {
  href,
  title,
  excerpt,
  cover,
  coverAlt,
  publishedAt,
  category,
  variant = 'default',
  class: className = '',
} = Astro.props;

const categoryToneClass = {
  pembangunan: 'bg-primary text-on-primary',
  lingkungan: 'bg-on-secondary-container text-white',
  sosial: 'bg-tertiary text-on-tertiary',
  wisata: 'bg-secondary text-on-secondary',
  umum: 'bg-surface-variant text-on-surface-variant',
}[category] ?? 'bg-primary text-on-primary';

const categoryLabel = {
  pembangunan: 'Pembangunan',
  lingkungan: 'Lingkungan',
  sosial: 'Sosial',
  wisata: 'Wisata',
  umum: 'Umum',
}[category] ?? category;
---
{variant === 'horizontal' && (
  <a href={href} class={`group flex gap-6 bg-surface-container-lowest rounded-[24px] overflow-hidden hover:shadow-xl transition-shadow ${className}`.trim()}>
    <div class="w-32 md:w-48 flex-shrink-0 overflow-hidden">
      <img class="w-full h-full object-cover transition-transform group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
    </div>
    <div class="flex-1 py-4 pr-6 space-y-2">
      <span class={`inline-block px-3 py-1 rounded-lg text-label-caps font-label-caps ${categoryToneClass}`}>{categoryLabel}</span>
      <h4 class="font-bold text-lg group-hover:text-primary transition-colors line-clamp-2">{title}</h4>
      <p class="text-on-surface-variant text-body-md line-clamp-2">{excerpt}</p>
      <p class="text-on-surface-variant text-label-caps">{formatLong(publishedAt)}</p>
    </div>
  </a>
)}

{variant === 'compact' && (
  <a href={href} class={`group flex items-center gap-4 ${className}`.trim()}>
    <div class="w-20 h-20 flex-shrink-0 overflow-hidden rounded-2xl">
      <img class="w-full h-full object-cover transition-transform group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
    </div>
    <div class="flex-1 space-y-1">
      <h5 class="font-bold text-on-surface group-hover:text-primary transition-colors line-clamp-2">{title}</h5>
      <p class="text-on-surface-variant text-label-caps">{formatLong(publishedAt)}</p>
    </div>
  </a>
)}

{variant === 'featured' && (
  <a href={href} class={`group block bg-surface-container-lowest rounded-[24px] overflow-hidden shadow-md hover:shadow-xl transition-shadow ${className}`.trim()}>
    <div class="aspect-[16/9] overflow-hidden relative">
      <img class="w-full h-full object-cover transition-transform group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
      <div class={`absolute top-4 left-4 px-3 py-1 rounded-lg text-label-caps font-label-caps ${categoryToneClass}`}>{categoryLabel}</div>
    </div>
    <div class="p-8 space-y-4">
      <div class="flex items-center gap-2 text-on-surface-variant text-label-caps">
        <Icon name="calendar_today" size={16} />
        {formatLong(publishedAt)}
      </div>
      <h3 class="font-headline-md text-headline-md group-hover:text-primary transition-colors">{title}</h3>
      <p class="text-on-surface-variant text-body-md line-clamp-3">{excerpt}</p>
      <span class="text-primary font-bold inline-flex items-center gap-1">
        Baca Selengkapnya <Icon name="arrow_forward" size={18} />
      </span>
    </div>
  </a>
)}

{variant === 'default' && (
  <a href={href} class={`group block bg-surface-container-lowest rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl transition-shadow ${className}`.trim()}>
    <div class="h-48 overflow-hidden relative">
      <img class="w-full h-full object-cover transition-transform group-hover:scale-110" src={cover} alt={coverAlt} loading="lazy" />
      <div class={`absolute top-4 left-4 px-3 py-1 rounded-lg text-label-caps font-label-caps ${categoryToneClass}`}>{categoryLabel}</div>
    </div>
    <div class="p-6 space-y-4">
      <div class="flex items-center gap-2 text-on-surface-variant text-label-caps">
        <Icon name="calendar_today" size={16} />
        {formatLong(publishedAt)}
      </div>
      <h4 class="font-bold text-xl group-hover:text-primary transition-colors line-clamp-2">{title}</h4>
      <p class="text-on-surface-variant line-clamp-3">{excerpt}</p>
      <hr class="border-outline-variant/30" />
      <span class="text-primary font-bold inline-flex items-center gap-1">
        Baca Selengkapnya <Icon name="arrow_forward" size={18} />
      </span>
    </div>
  </a>
)}
