---
interface Props {
  label: string;
  name: string;
  placeholder?: string;
  required?: boolean;
  rows?: number;
}

const { label, name, placeholder, required = false, rows = 5 } = Astro.props;
const id = `field-${name}`;
---
<div class="space-y-2">
  <label class="block font-label-caps text-on-surface text-label-caps" for={id}>
    {label}{required && <span class="text-error ml-1">*</span>}
  </label>
  <textarea
    id={id}
    name={name}
    rows={rows}
    placeholder={placeholder}
    required={required}
    class="w-full px-4 py-3 rounded-2xl bg-surface-container-lowest border border-outline-variant text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition resize-y"
  ></textarea>
</div>
