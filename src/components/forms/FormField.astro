---
interface Props {
  label: string;
  name: string;
  type?: 'text' | 'email' | 'tel' | 'url' | 'date';
  placeholder?: string;
  required?: boolean;
  helpText?: string;
}

const { label, name, type = 'text', placeholder, required = false, helpText } = Astro.props;
const id = `field-${name}`;
---
<div class="space-y-2">
  <label class="block font-label-caps text-on-surface text-label-caps" for={id}>
    {label}{required && <span class="text-error ml-1">*</span>}
  </label>
  <input
    id={id}
    name={name}
    type={type}
    placeholder={placeholder}
    required={required}
    class="w-full px-4 py-3 rounded-2xl bg-surface-container-lowest border border-outline-variant text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition"
  />
  {helpText && <p class="text-label-caps text-on-surface-variant">{helpText}</p>}
</div>
