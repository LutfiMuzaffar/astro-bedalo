---
interface Option {
  value: string;
  label: string;
}

interface Props {
  label: string;
  name: string;
  options: Option[];
  required?: boolean;
}

const { label, name, options, required = false } = Astro.props;
const id = `field-${name}`;
---
<div class="space-y-2">
  <label class="block font-label-caps text-on-surface text-label-caps" for={id}>
    {label}{required && <span class="text-error ml-1">*</span>}
  </label>
  <select
    id={id}
    name={name}
    required={required}
    class="w-full px-4 py-3 rounded-2xl bg-surface-container-lowest border border-outline-variant text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition"
  >
    <option value="">— Pilih —</option>
    {options.map((o) => <option value={o.value}>{o.label}</option>)}
  </select>
</div>
