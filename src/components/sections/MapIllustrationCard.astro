---
import Icon from '@components/ui/Icon.astro';

interface Props {
  mapImage: string;
  mapAlt?: string;
  pinLabel: string;
  /** Tailwind height class. */
  height?: string;
  class?: string;
}

const {
  mapImage,
  mapAlt = 'Peta lokasi',
  pinLabel,
  height = 'h-64 md:h-80',
  class: className = '',
} = Astro.props;
---
<div class={`w-full ${height} rounded-[24px] overflow-hidden shadow-[0_8px_30px_-4px_rgba(2,62,138,0.05)] bg-surface-container relative ${className}`.trim()}>
  <img class="w-full h-full object-cover opacity-80" src={mapImage} alt={mapAlt} />
  <div class="absolute inset-0 bg-gradient-to-t from-on-secondary-container/80 to-transparent flex items-end p-6">
    <div class="flex items-center gap-2 text-surface-container-lowest">
      <Icon name="location_on" filled />
      <span class="font-headline-sm text-headline-sm">{pinLabel}</span>
    </div>
  </div>
</div>
