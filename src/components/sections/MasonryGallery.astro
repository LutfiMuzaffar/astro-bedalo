---
interface PhotoItem {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  photos: PhotoItem[];
  columns?: 2 | 3 | 4;
  class?: string;
}

const { photos, columns = 3, class: className = '' } = Astro.props;

const colsClass = {
  2: 'columns-1 md:columns-2',
  3: 'columns-1 md:columns-2 lg:columns-3',
  4: 'columns-1 md:columns-2 lg:columns-3 xl:columns-4',
}[columns];
---
<div class={`${colsClass} gap-4 space-y-4 ${className}`.trim()}>
  {photos.map((photo) => (
    <figure class="break-inside-avoid rounded-[24px] overflow-hidden shadow-sm">
      <img class="w-full hover:scale-105 transition-transform duration-500" src={photo.src} alt={photo.alt} loading="lazy" />
      {photo.caption && (
        <figcaption class="px-4 py-3 bg-surface-container-lowest text-body-md text-on-surface-variant">{photo.caption}</figcaption>
      )}
    </figure>
  ))}
</div>
