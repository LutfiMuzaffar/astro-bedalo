---
import Button from '@components/ui/Button.astro';

interface Props {
  primaryImage: string;
  primaryAlt: string;
  secondaryImage: string;
  secondaryAlt: string;
}

const { primaryImage, primaryAlt, secondaryImage, secondaryAlt } = Astro.props;
---
<section class="mt-section-gap relative py-20 overflow-hidden">
  <div class="absolute inset-0 bg-on-secondary-container"></div>
  <div class="absolute top-0 right-0 w-full h-full opacity-10">
    <svg viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M0,500 C0,223.857625 223.857625,0 500,0 C776.142375,0 1000,223.857625 1000,500 C1000,776.142375 776.142375,1000 500,1000 C223.857625,1000 0,776.142375 0,500"
        fill="white"
      />
    </svg>
  </div>
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative z-10 flex flex-col md:flex-row items-center gap-12 text-on-primary-container">
    <div class="flex-1 space-y-6">
      <span class="bg-primary-container px-4 py-1 rounded-full text-label-caps text-[12px] font-bold">JEJAK BAKTI</span>
      <h2 class="font-display-lg text-headline-md md:text-display-lg">Memori Pengabdian Mahasiswa</h2>
      <p class="text-lg opacity-90 max-w-xl">
        Dusun Bedalo adalah rumah bagi ribuan cerita pengabdian. Lihat bagaimana
        kolaborasi mahasiswa KKN dan warga membentuk Dusun Bedalo yang sekarang.
      </p>
      <Button variant="primary" size="lg" href="/kkn" class="!bg-surface-bright !text-on-secondary-container hover:scale-105 transition-transform">
        Buka Arsip KKN
      </Button>
    </div>
    <div class="flex-1 grid grid-cols-2 gap-4">
      <div class="bg-white/10 p-2 rounded-2xl backdrop-blur-md rotate-3 translate-y-4">
        <img class="rounded-xl grayscale hover:grayscale-0 transition-all" src={primaryImage} alt={primaryAlt} />
      </div>
      <div class="bg-white/10 p-2 rounded-2xl backdrop-blur-md -rotate-3">
        <img class="rounded-xl grayscale hover:grayscale-0 transition-all" src={secondaryImage} alt={secondaryAlt} />
      </div>
    </div>
  </div>
</section>
