---
import Icon from '@components/ui/Icon.astro';

interface Props {
  wisata: { href: string; name: string; tagline: string; cover: string; coverAlt: string };
  pertanian: { href: string; name: string; tagline: string; cover: string; coverAlt: string };
  kerajinan: { href: string; name: string; tagline: string; cover: string; coverAlt: string };
}

const { wisata, pertanian, kerajinan } = Astro.props;
---
<section class="mt-section-gap bg-on-secondary-container/5 py-24">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="flex justify-between items-end mb-12">
      <div>
        <p class="text-label-caps text-on-secondary-container font-bold mb-2">KEKAYAAN LOKAL</p>
        <h2 class="font-headline-md text-headline-md text-on-surface">Potensi Desa Kami</h2>
      </div>
      <a class="text-primary font-bold hover:underline flex items-center gap-2" href="/potensi">
        Lihat Semua Potensi <Icon name="chevron_right" />
      </a>
    </div>
    <div class="grid md:grid-cols-12 gap-gutter">
      <a
        href={wisata.href}
        class="md:col-span-8 group relative overflow-hidden rounded-[24px] aspect-[16/9] shadow-md transition-transform duration-500 hover:-translate-y-2 block"
      >
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={wisata.cover} alt={wisata.coverAlt} />
        <div class="absolute inset-0 bg-gradient-to-t from-on-secondary-container/90 via-on-secondary-container/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-8">
          <span class="bg-secondary text-on-secondary px-3 py-1 rounded-full text-label-caps text-[10px] mb-4 inline-block">WISATA ALAM</span>
          <h3 class="text-white font-headline-md text-headline-md mb-2">{wisata.name}</h3>
          <p class="text-surface-variant/90 max-w-md">{wisata.tagline}</p>
        </div>
      </a>
      <a
        href={pertanian.href}
        class="md:col-span-4 group relative overflow-hidden rounded-[24px] aspect-square shadow-md transition-transform duration-500 hover:-translate-y-2 block"
      >
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={pertanian.cover} alt={pertanian.coverAlt} />
        <div class="absolute inset-0 bg-gradient-to-t from-tertiary-container/90 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6">
          <span class="bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-label-caps text-[10px] mb-4 inline-block">PERTANIAN</span>
          <h3 class="text-white font-headline-sm text-headline-sm mb-2">{pertanian.name}</h3>
          <p class="text-white/80 text-body-md">{pertanian.tagline}</p>
        </div>
      </a>
      <a
        href={kerajinan.href}
        class="md:col-span-12 group relative overflow-hidden rounded-[24px] h-[300px] shadow-md transition-transform duration-500 hover:-translate-y-2 block"
      >
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src={kerajinan.cover} alt={kerajinan.coverAlt} />
        <div class="absolute inset-0 bg-gradient-to-r from-on-surface/80 via-on-surface/20 to-transparent"></div>
        <div class="absolute inset-0 p-8 flex flex-col justify-center">
          <span class="bg-surface-variant text-on-surface-variant px-3 py-1 rounded-full text-label-caps text-[10px] mb-4 w-fit">KERAJINAN</span>
          <h3 class="text-white font-headline-md text-headline-md mb-2">{kerajinan.name}</h3>
          <p class="text-white/80 max-w-xl">{kerajinan.tagline}</p>
        </div>
      </a>
    </div>
  </div>
</section>
