---
import Icon from '@components/ui/Icon.astro';
import Button from '@components/ui/Button.astro';

interface Props {
  primaryImage: string;
  primaryAlt: string;
  secondaryImage: string;
  secondaryAlt: string;
}

const { primaryImage, primaryAlt, secondaryImage, secondaryAlt } = Astro.props;
---
<section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-16 md:py-24 grid md:grid-cols-2 gap-16 items-center">
  <div class="space-y-8">
    <div class="inline-flex items-center gap-2 px-4 py-1 bg-primary-fixed text-on-primary-fixed-variant rounded-full text-label-caps font-label-caps">
      <Icon name="waves" size={16} />
      EXPLORE GUNUNGKIDUL
    </div>
    <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg leading-tight text-on-surface">
      Selamat Datang di <span class="text-primary">Dusun Bedalo</span>
    </h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant max-w-lg">
      Dusun pesisir nan asri di Krambilsawit, Saptosari, Gunungkidul, di mana
      tradisi dan keindahan alam berpadu.
    </p>
    <div class="flex flex-wrap gap-4 pt-4">
      <Button variant="on-secondary" size="lg" href="/potensi" icon="arrow_forward">
        Jelajahi Potensi
      </Button>
      <Button variant="ghost" size="lg" href="/berita">
        Lihat Berita Terbaru
      </Button>
    </div>
  </div>

  <!-- Asymmetrical Photo Collage -->
  <div class="relative h-[500px]">
    <div class="absolute top-0 right-0 w-[80%] h-[80%] rounded-[48px] overflow-hidden shadow-xl transform rotate-3">
      <img class="w-full h-full object-cover" src={primaryImage} alt={primaryAlt} />
    </div>
    <div class="absolute bottom-4 left-0 w-[60%] h-[50%] rounded-[32px] overflow-hidden border-8 border-surface-bright shadow-2xl transform -rotate-6">
      <img class="w-full h-full object-cover" src={secondaryImage} alt={secondaryAlt} />
    </div>
    <!-- Floating Badges -->
    <div class="absolute top-10 left-10 bg-surface-container-lowest/90 backdrop-blur-sm p-4 rounded-2xl shadow-lg flex items-center gap-3 animate-bounce">
      <div class="bg-secondary-container p-2 rounded-xl text-on-secondary-fixed-variant">
        <Icon name="beach_access" />
      </div>
      <div>
        <p class="text-label-caps font-bold text-on-surface">Pesisir Selatan</p>
        <p class="text-[10px] text-on-surface-variant">Gunungkidul Regency</p>
      </div>
    </div>
    <div class="absolute bottom-20 right-0 bg-surface-container-lowest/90 backdrop-blur-sm p-4 rounded-2xl shadow-lg flex items-center gap-3">
      <div class="bg-tertiary-container p-2 rounded-xl text-on-tertiary-container">
        <Icon name="home_work" />
      </div>
      <div>
        <p class="text-label-caps font-bold text-on-surface">4 Pantai</p>
        <p class="text-[10px] text-on-surface-variant">Wisata Alam Eksotis</p>
      </div>
    </div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col gap-2">
      <span class="bg-primary/90 text-white px-4 py-1 rounded-full text-label-caps text-[10px] shadow-sm">UMKM Lokal</span>
      <span class="bg-on-secondary-container/90 text-white px-4 py-1 rounded-full text-label-caps text-[10px] shadow-sm ml-4">Budaya Warga</span>
    </div>
  </div>
</section>
