---
import Icon from '@components/ui/Icon.astro';
---
<form class="relative">
  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">
    <Icon name="search" />
  </span>
  <input
    type="text"
    name="q"
    placeholder="Cari berita atau agenda..."
    class="w-full pl-12 pr-4 py-3 rounded-full border-none bg-surface-container-low text-on-surface focus:ring-2 focus:ring-primary focus:bg-surface-container-lowest transition-all font-body-md text-body-md"
  />
</form>
