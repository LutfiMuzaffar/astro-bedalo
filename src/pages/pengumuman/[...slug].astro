---
import { getCollection, type CollectionEntry } from 'astro:content';
import PublicLayout from '@layouts/PublicLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';
import Icon from '@components/ui/Icon.astro';
import { formatLong } from '@lib/date';

export async function getStaticPaths() {
  const items = await getCollection('pengumuman');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: CollectionEntry<'pengumuman'>;
}

const { item } = Astro.props;
const { Content } = await item.render();

const urgencyClass = {
  info: 'bg-primary-fixed text-on-primary-fixed-variant',
  penting: 'bg-tertiary-fixed text-on-tertiary-fixed-variant',
  darurat: 'bg-error-container text-on-error-container',
}[item.data.urgency];

const urgencyLabel = {
  info: 'Info',
  penting: 'Penting',
  darurat: 'Darurat',
}[item.data.urgency];
---
<PublicLayout title={`${item.data.title} - Pengumuman`} description={item.data.excerpt} active="agenda-berita">
  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop pb-16">
    <Breadcrumb
      class="mb-6"
      items={[
        { label: 'Home', href: '/' },
        { label: 'Pengumuman', href: '/pengumuman' },
        { label: item.data.title },
      ]}
    />
    <header class="space-y-4 mb-8">
      <span class={`inline-block px-4 py-1 rounded-full text-label-caps font-label-caps ${urgencyClass}`}>{urgencyLabel.toUpperCase()}</span>
      <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface">{item.data.title}</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">{item.data.excerpt}</p>
      <div class="flex flex-wrap items-center gap-4 text-on-surface-variant text-body-md">
        <span class="flex items-center gap-2"><Icon name="calendar_today" /> {formatLong(item.data.publishedAt)}</span>
        <span class="flex items-center gap-2"><Icon name="account_balance" /> {item.data.issuer}</span>
        {item.data.expiresAt && (
          <span class="flex items-center gap-2 text-error">
            <Icon name="event_busy" /> Berlaku hingga {formatLong(item.data.expiresAt)}
          </span>
        )}
      </div>
    </header>
    <div class="prose prose-lg max-w-none [&_p]:text-body-lg [&_p]:text-on-surface-variant [&_p]:mb-4">
      <Content />
    </div>
    {item.data.attachments.length > 0 && (
      <div class="mt-8 space-y-2">
        <h3 class="font-headline-sm text-headline-sm text-on-surface">Lampiran</h3>
        <ul class="space-y-2">
          {item.data.attachments.map((att) => (
            <li>
              <a href={att.href} class="inline-flex items-center gap-2 text-primary hover:underline">
                <Icon name="attachment" /> {att.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </article>
</PublicLayout>
