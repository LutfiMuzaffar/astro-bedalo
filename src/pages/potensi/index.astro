---
import { getCollection } from 'astro:content';
import PublicLayout from '@layouts/PublicLayout.astro';
import PageHero from '@components/sections/PageHero.astro';
import WisataCard from '@components/cards/WisataCard.astro';
import UmkmCard from '@components/cards/UmkmCard.astro';
import { IMG_HANDICRAFT, IMG_FARMING, IMG_BEACH_HIDDEN } from '@lib/images';

const wisata = (await getCollection('wisata'))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 4);

const umkm = (await getCollection('umkm')).slice(0, 3);
const kuliner = (await getCollection('kuliner')).slice(0, 3);
---
<PublicLayout title="Potensi Desa - Dusun Bedalo" active="potensi">
  <PageHero
    eyebrow="KEKAYAAN LOKAL"
    title="Potensi Desa Kami"
    description="Empat pilar kekuatan Dusun Bedalo: wisata pesisir, pertanian karst, kerajinan warga, dan kuliner pesisir."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Potensi' }]}
  />

  <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pb-16 space-y-section-gap">
    <div class="space-y-6">
      <div class="flex justify-between items-end flex-wrap gap-4">
        <div>
          <p class="font-label-caps text-label-caps text-primary mb-2">WISATA</p>
          <h2 class="font-headline-md text-headline-md text-on-surface">Pesona Pantai &amp; Karst</h2>
        </div>
        <a href="/potensi/wisata" class="text-primary font-bold hover:underline">Lihat Semua →</a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {wisata.map((w) => (
          <WisataCard
            href={`/potensi/wisata/${w.slug}`}
            name={w.data.name}
            tagline={w.data.tagline}
            cover={w.data.cover}
            coverAlt={w.data.coverAlt}
            type={w.data.type}
            facilities={w.data.facilities}
          />
        ))}
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-gutter mt-section-gap">
      <a href="/potensi/wisata" class="group relative aspect-[4/5] rounded-[24px] overflow-hidden shadow-md">
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={IMG_BEACH_HIDDEN} alt="Pantai Bedalo" />
        <div class="absolute inset-0 bg-gradient-to-t from-on-secondary-container/95 via-on-secondary-container/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6 text-white">
          <p class="font-label-caps text-white/80">WISATA</p>
          <h3 class="font-headline-sm text-headline-sm">Pantai &amp; Karst</h3>
        </div>
      </a>
      <a href="/potensi/pertanian" class="group relative aspect-[4/5] rounded-[24px] overflow-hidden shadow-md">
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={IMG_FARMING} alt="Pertanian Bedalo" />
        <div class="absolute inset-0 bg-gradient-to-t from-tertiary-container/95 via-tertiary-container/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6 text-white">
          <p class="font-label-caps text-white/80">PERTANIAN</p>
          <h3 class="font-headline-sm text-headline-sm">Labu &amp; Palawija</h3>
        </div>
      </a>
      <a href="/potensi/kerajinan" class="group relative aspect-[4/5] rounded-[24px] overflow-hidden shadow-md">
        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={IMG_HANDICRAFT} alt="Kerajinan Bedalo" />
        <div class="absolute inset-0 bg-gradient-to-t from-on-surface/95 via-on-surface/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6 text-white">
          <p class="font-label-caps text-white/80">KERAJINAN</p>
          <h3 class="font-headline-sm text-headline-sm">Tenun &amp; Anyaman</h3>
        </div>
      </a>
    </div>

    <div class="space-y-6 mt-section-gap">
      <div class="flex justify-between items-end flex-wrap gap-4">
        <div>
          <p class="font-label-caps text-label-caps text-primary mb-2">EKONOMI WARGA</p>
          <h2 class="font-headline-md text-headline-md text-on-surface">UMKM Bedalo</h2>
        </div>
        <a href="/potensi/umkm" class="text-primary font-bold hover:underline">Lihat Semua →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {umkm.map((u) => (
          <UmkmCard
            href={`/potensi/umkm/${u.slug}`}
            name={u.data.name}
            category={u.data.category}
            summary={u.data.summary}
            cover={u.data.cover}
            coverAlt={u.data.coverAlt}
            owner={u.data.owner}
          />
        ))}
      </div>
    </div>

    <div class="space-y-6 mt-section-gap">
      <div class="flex justify-between items-end flex-wrap gap-4">
        <div>
          <p class="font-label-caps text-label-caps text-primary mb-2">RASA LOKAL</p>
          <h2 class="font-headline-md text-headline-md text-on-surface">Kuliner Pesisir</h2>
        </div>
        <a href="/potensi/kuliner" class="text-primary font-bold hover:underline">Lihat Semua →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {kuliner.map((k) => (
          <a href={`/potensi/kuliner/${k.slug}`} class="group block bg-surface-container-lowest rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl transition-shadow">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={k.data.cover} alt={k.data.coverAlt} class="w-full h-full object-cover transition-transform group-hover:scale-110" loading="lazy" />
            </div>
            <div class="p-6 space-y-2">
              <h4 class="font-headline-sm text-headline-sm group-hover:text-primary transition-colors">{k.data.name}</h4>
              <p class="text-on-surface-variant line-clamp-2">{k.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</PublicLayout>
