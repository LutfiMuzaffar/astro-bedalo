---
import { getCollection, type CollectionEntry } from 'astro:content';
import PublicLayout from '@layouts/PublicLayout.astro';
import Breadcrumb from '@components/ui/Breadcrumb.astro';

export async function getStaticPaths() {
  const items = await getCollection('kuliner');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: CollectionEntry<'kuliner'>;
}

const { item } = Astro.props;
const { Content } = await item.render();
---
<PublicLayout title={`${item.data.name} - Kuliner Bedalo`} description={item.data.summary} ogImage={item.data.cover} active="potensi">
  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop pb-16">
    <Breadcrumb
      class="mb-6"
      items={[
        { label: 'Home', href: '/' },
        { label: 'Potensi', href: '/potensi' },
        { label: 'Kuliner', href: '/potensi/kuliner' },
        { label: item.data.name },
      ]}
    />
    <header class="space-y-4 mb-8">
      <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface">{item.data.name}</h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant">{item.data.summary}</p>
    </header>
    <div class="aspect-[16/9] overflow-hidden rounded-[24px] mb-8">
      <img src={item.data.cover} alt={item.data.coverAlt} class="w-full h-full object-cover" />
    </div>
    {item.data.ingredients.length > 0 && (
      <div class="bg-surface-container-lowest rounded-[24px] p-6 mb-8 space-y-2">
        <p class="font-label-caps text-on-surface-variant">BAHAN UTAMA</p>
        <ul class="flex flex-wrap gap-2">
          {item.data.ingredients.map((ing) => (
            <li class="px-3 py-1 rounded-full bg-surface-container text-on-surface text-body-md">{ing}</li>
          ))}
        </ul>
      </div>
    )}
    <div class="prose prose-lg max-w-none [&_h2]:font-headline-md [&_h2]:text-headline-md [&_h2]:mt-8 [&_h2]:mb-4 [&_p]:text-body-lg [&_p]:text-on-surface-variant [&_p]:mb-4 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:text-on-surface-variant">
      <Content />
    </div>
    {item.data.soldBy.length > 0 && (
      <div class="mt-10 bg-surface-container-lowest rounded-[24px] p-6 space-y-2">
        <p class="font-label-caps text-on-surface-variant">DIJUAL OLEH</p>
        <ul class="space-y-1">
          {item.data.soldBy.map((s) => (
            <li class="text-body-md text-on-surface">{s}</li>
          ))}
        </ul>
      </div>
    )}
  </article>
</PublicLayout>
