---
import { getCollection } from 'astro:content';
import PublicLayout from '@layouts/PublicLayout.astro';
import PageHero from '@components/sections/PageHero.astro';

const all = await getCollection('kuliner');
---
<PublicLayout title="Kuliner Pesisir - Dusun Bedalo" active="potensi">
  <PageHero
    eyebrow="RASA LOKAL"
    title="Kuliner Pesisir Bedalo"
    description="Sajian khas hasil pertemuan dapur warga dengan kekayaan laut Saptosari."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Potensi', href: '/potensi' },
      { label: 'Kuliner' },
    ]}
  />

  <section class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop pb-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-gutter">
      {all.map((k) => (
        <a href={`/potensi/kuliner/${k.slug}`} class="group block bg-surface-container-lowest rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl transition-shadow">
          <div class="aspect-[4/3] overflow-hidden">
            <img src={k.data.cover} alt={k.data.coverAlt} class="w-full h-full object-cover transition-transform group-hover:scale-110" loading="lazy" />
          </div>
          <div class="p-6 space-y-2">
            <h4 class="font-headline-sm text-headline-sm group-hover:text-primary transition-colors">{k.data.name}</h4>
            <p class="text-on-surface-variant line-clamp-2">{k.data.summary}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</PublicLayout>
