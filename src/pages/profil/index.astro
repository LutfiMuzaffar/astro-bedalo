---
import PublicLayout from '@layouts/PublicLayout.astro';
import SinglePhotoHero from '@components/sections/SinglePhotoHero.astro';
import Icon from '@components/ui/Icon.astro';
import { IMG_VILLAGE_AERIAL } from '@lib/images';

const cards = [
  {
    href: '/profil/tentang',
    icon: 'info',
    title: 'Tentang Dusun',
    body: 'Sejarah singkat, visi misi, dan gambaran umum mengenai karakter Dusun Bedalo.',
  },
  {
    href: '/profil/letak-geografis',
    icon: 'map',
    title: 'Letak Geografis',
    body: 'Batas wilayah, topografi, dan potensi bentang alam pesisir selatan.',
  },
  {
    href: '/profil/demografi',
    icon: 'group',
    title: 'Demografi',
    body: 'Data kependudukan, mata pencaharian, dan struktur usia masyarakat.',
  },
  {
    href: '/profil/pemerintahan',
    icon: 'account_balance',
    title: 'Pemerintahan Dusun',
    body: 'Struktur organisasi lembaga kemasyarakatan dan perangkat kewilayahan.',
  },
  {
    href: '/profil/fasilitas',
    icon: 'local_hospital',
    title: 'Fasilitas Umum',
    body: 'Infrastruktur pendidikan, kesehatan, ibadah, dan sarana olahraga.',
  },
  {
    href: '/profil/sosial-budaya',
    icon: 'festival',
    title: 'Sosial, Agama & Budaya',
    body: 'Kerukunan umat, tradisi rasulan, dan kelompok kesenian lokal.',
  },
];
---
<PublicLayout title="Profil Dusun Bedalo" active="profil" mainClass="overflow-hidden">
  <SinglePhotoHero
    eyebrow="Mengenal Desa Kami"
    title="Profil Dusun"
    titleHighlight="Bedalo"
    body="Menelusuri jejak warisan pesisir, kehidupan agraris yang harmonis, dan kearifan lokal yang mengakar kuat di selatan Gunungkidul. Dusun Bedalo adalah cerminan keseimbangan alam dan tradisi."
    photo={IMG_VILLAGE_AERIAL}
    photoAlt="Pemandangan udara Dusun Bedalo, perpaduan ladang hijau dan pesisir biru."
    cornerBadgeTitle="Sejak 1900-an"
    cornerBadgeBody="Menjaga tradisi lintas generasi."
    variant="profil"
  />

  <section class="py-section-gap px-margin-mobile md:px-margin-desktop bg-surface-container-lowest">
    <div class="max-w-container-max mx-auto">
      <div class="text-center mb-16 max-w-3xl mx-auto">
        <h2 class="font-headline-md text-headline-md text-on-background mb-4">Eksplorasi Profil</h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant">
          Pelajari lebih dalam tentang berbagai aspek kehidupan, pemerintahan, dan geografi Dusun Bedalo.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {cards.map((c) => (
          <a
            class="group block p-8 rounded-[24px] bg-background hover:bg-surface-container transition-colors duration-300 shadow-[0_4px_20px_-4px_rgba(2,62,138,0.05)]"
            href={c.href}
          >
            <div class="w-12 h-12 rounded-full bg-primary-fixed flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
              <Icon name={c.icon} filled />
            </div>
            <h3 class="font-headline-sm text-headline-sm text-on-background mb-3">{c.title}</h3>
            <p class="font-body-md text-body-md text-on-surface-variant">{c.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</PublicLayout>
